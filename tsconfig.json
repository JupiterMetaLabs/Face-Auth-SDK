{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-native",
    "composite": true,
    "emitDeclarationOnly": true
  },
  "include": [
    "index.ts",
    "FaceZkSdk.ts",
    "core/**/*.ts",
    "config/**/*.ts",
    "react-native/**/*.ts",
    "react-native/**/*.tsx",
    "storage/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "example"
  ]
}
