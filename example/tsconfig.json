{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@jupitermetalabs/face-zk-sdk": ["../index.ts"],
      "@jupitermetalabs/face-zk-sdk/react-native": ["../react-native/index.ts"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../core/**/*.ts",
    "../core/**/*.tsx",
    "../react-native/**/*.ts",
    "../react-native/**/*.tsx",
    "../storage/**/*.ts",
    "../storage/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}

